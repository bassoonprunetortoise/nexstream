{
  "name": "nexstream-ott",
  "version": "1.0.0",
  "private": true,
  "description": "NexStream OTT Platform - Netflix/Disney+ Grade Streaming",
  "author": "NexStream Team",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "test": "turbo run test",
